# Sample Environment Variables for Gagan Hospital AI Assistant
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/gagan_hospital

# Alternative Database Configuration (if not using DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=your_postgres_username
PGPASSWORD=your_postgres_password
PGDATABASE=gagan_hospital

# Server Configuration
PORT=5051
NODE_ENV=development

# Twilio Configuration (for webhook verification and optional features)
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
YOUR_VERIFIED_PHONE_NUMBER=+12295924640


